---
import Base from '../layouts/Base.astro';
---
<Base title="HCS — Selected Work" screenLabel="Work Index" active="work">
<style is:global>
  .work-hero{ padding: clamp(40px,8vh,96px) var(--pad) 60px; border-bottom: 1px solid var(--rule); }
  .work-hero .grid{ display:grid; grid-template-columns: 2fr 1fr; gap: 40px; align-items: end; }
  .work-hero h1{
    font-family: var(--serif); font-weight: 400; margin: 0;
    font-size: clamp(56px, 11vw, 200px); line-height: 0.92; letter-spacing: -0.025em;
  }
  .work-hero h1 .it{ font-style: italic; color: var(--muted); }
  .work-hero .meta{ color: var(--ink-2); }
  .work-hero .index-line{
    margin-top: 28px; padding-top: 14px; border-top: 1px solid var(--rule);
    display:flex; gap: 32px; flex-wrap: wrap;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
  }

  .filters{
    padding: 24px var(--pad); display:flex; gap: 8px; flex-wrap: wrap;
    border-bottom: 1px solid var(--rule);
  }
  .filters button{
    background: transparent; border: 1px solid var(--rule); color: var(--ink-2);
    padding: 8px 16px; border-radius: 999px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    cursor: pointer; transition: all .2s ease;
  }
  .filters button:hover{ color: var(--ink); border-color: var(--rule-strong); }
  .filters button.active{ background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .index{
    padding: 40px var(--pad) 80px;
  }
  .row-h{
    display: grid; grid-template-columns: 60px 1.6fr 1fr 1fr 80px;
    gap: 24px; padding: 14px 0;
    border-bottom: 1px solid var(--rule-strong);
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
  }
  .row{
    display: grid; grid-template-columns: 60px 1.6fr 1fr 1fr 80px;
    gap: 24px; padding: 28px 0;
    border-bottom: 1px solid var(--rule);
    align-items: center;
    cursor: pointer;
    position: relative;
    transition: padding .3s ease;
  }
  .row:hover{ padding-left: 12px; padding-right: 12px; }
  .row .num{ font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .row .name{
    font-family: var(--serif); font-size: clamp(28px, 3vw, 44px); line-height: 1; letter-spacing: -0.015em;
  }
  .row .name .it{ font-style: italic; color: var(--muted); }
  .row .cat, .row .yr{ font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-2); }
  .row .arr{ text-align: right; font-family: var(--mono); font-size: 14px; opacity: 0; transition: opacity .25s ease; }
  .row:hover .arr{ opacity: 1; }

  .preview{
    position: fixed; pointer-events: none; z-index: 100;
    width: 380px; aspect-ratio: 4/3; border-radius: 8px; border: 1px solid var(--rule-strong);
    overflow: hidden;
    transform: translate(-50%, -50%) scale(.96); opacity: 0;
    transition: opacity .25s ease, transform .25s ease;
  }
  .preview.show{ opacity: 1; transform: translate(-50%, -50%) scale(1); }

  .art-allthings{ background: radial-gradient(120% 80% at 30% 20%, rgba(201,168,107,0.18), transparent 60%), linear-gradient(180deg, #1a2030 0%, #0c1018 100%); }
  .art-allthings::before{ content:""; position:absolute; inset:0; background: repeating-linear-gradient(0deg, rgba(232,230,225,0.06) 0 1px, transparent 1px 64px), repeating-linear-gradient(90deg, rgba(232,230,225,0.06) 0 1px, transparent 1px 64px); }
  .art-allthings::after{ content:"AT/D"; position:absolute; left: 32px; top: 32px; font-family: var(--serif); font-style: italic; font-size: clamp(48px, 9vw, 120px); color: var(--ink); line-height:1; }
  .art-robin{ background: linear-gradient(180deg, #0f141d 0%, #161b27 100%); }
  .art-robin::after{ content:"Robin"; position:absolute; left: 28px; bottom: 28px; font-family: var(--serif); font-style: italic; font-size: 60px; color: var(--accent);}
  .art-mysi{ background: linear-gradient(180deg, #1c1816 0%, #0f0d0c 100%); }
  .art-mysi::after{ content:"My·SI"; position:absolute; right: 36px; bottom: 30px; font-family: var(--serif); font-style: italic; font-size: 60px; color: var(--accent); }
  .art-vas{ background: radial-gradient(80% 60% at 80% 20%, rgba(124,138,160,0.25), transparent 60%), linear-gradient(180deg, #11161e 0%, #0a0d12 100%); }
  .art-vas::after{ content:"VAS"; position:absolute; left: 36px; bottom: 28px; font-family: var(--serif); font-style: italic; font-size: 60px; color: var(--ink); }
  .art-logistics{ background: linear-gradient(180deg, #0c1116 0%, #0a0e13 100%); }
  .art-logistics::after{ content:"Logistics"; position:absolute; left: 28px; bottom: 24px; font-family: var(--serif); font-style: italic; font-size: 56px; color: var(--accent); }

  @media (max-width: 900px){
    .row, .row-h{ grid-template-columns: 40px 1fr 1fr; }
    .row .yr, .row .arr, .row-h > *:nth-child(4), .row-h > *:nth-child(5){ display:none; }
    .preview{ display:none; }
  }
</style>

<section class="work-hero">
  <span class="eyebrow">§ Work — Selected Index</span>
  <div class="grid" style="margin-top: 24px;">
    <h1>Selected <span class="it">work,</span><br/>2024–2026.</h1>
    <p class="meta lede">Five projects across marketing sites, executive dashboards, learning systems, and live operations tools. Click through for case studies.</p>
  </div>
  <div class="index-line">
    <span>Vol. I — 5 entries</span>
    <span>Davis · Los Angeles · Remote</span>
    <span>Updated April 2026</span>
  </div>
</section>

<div class="filters" id="filters">
  <button class="active" data-f="all">All</button>
  <button data-f="web">Websites</button>
  <button data-f="dash">Dashboards</button>
  <button data-f="lms">LMS &amp; CRM</button>
  <button data-f="ops">Operations</button>
</div>

<section class="index">
  <div class="row-h">
    <span>№</span>
    <span>Project</span>
    <span>Category</span>
    <span>Year</span>
    <span></span>
  </div>

  <a class="row" id="robin" href="/work/robin" data-cat="dash" data-art="art-robin">
    <span class="num">001</span>
    <span class="name">Robin <span class="it">— exec dashboard</span></span>
    <span class="cat">Dashboard · Integrations</span>
    <span class="yr">2025</span>
    <span class="arr">→</span>
  </a>

  <a class="row" id="allthings" href="/work/allthings" data-cat="web" data-art="art-allthings">
    <span class="num">002</span>
    <span class="name">All Things Design <span class="it">— main site</span></span>
    <span class="cat">Brand · Web</span>
    <span class="yr">2025</span>
    <span class="arr">→</span>
  </a>

  <a class="row" id="mysi" href="/work/mysi" data-cat="lms" data-art="art-mysi">
    <span class="num">003</span>
    <span class="name">MySI <span class="it">— LMS &amp; CRM</span></span>
    <span class="cat">LMS · CRM · Funnel</span>
    <span class="yr">2024</span>
    <span class="arr">→</span>
  </a>

  <a class="row" id="vas" href="/work/vas" data-cat="ops" data-art="art-vas">
    <span class="num">004</span>
    <span class="name">VAS Interpretation <span class="it">— staff system</span></span>
    <span class="cat">Auth · Operations</span>
    <span class="yr">2024</span>
    <span class="arr">→</span>
  </a>

  <a class="row" id="logistics" href="/work/logistics" data-cat="ops" data-art="art-logistics">
    <span class="num">005</span>
    <span class="name">Logistics Co. <span class="it">— CRM + live tracking</span></span>
    <span class="cat">CRM · Real-time</span>
    <span class="yr">2024</span>
    <span class="arr">→</span>
  </a>
</section>

<div class="preview ph" id="preview"><div class="ph-art" id="previewArt" style="position:absolute; inset:0;"></div></div>

<script is:inline>
// Filters
document.querySelectorAll('#filters button').forEach(b => {
  b.addEventListener('click', ()=>{
    document.querySelectorAll('#filters button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    const f = b.dataset.f;
    document.querySelectorAll('.row').forEach(r => {
      r.style.display = (f === 'all' || r.dataset.cat === f) ? '' : 'none';
    });
  });
});

// Cursor preview
(function(){
  if (matchMedia('(pointer: coarse)').matches) return;
  const preview = document.getElementById('preview');
  const art = document.getElementById('previewArt');
  document.querySelectorAll('.row').forEach(r => {
    r.addEventListener('mouseenter', ()=>{
      art.className = 'ph-art';
      art.classList.add(r.dataset.art);
      preview.classList.add('show');
    });
    r.addEventListener('mouseleave', ()=> preview.classList.remove('show'));
    r.addEventListener('mousemove', (e)=>{
      preview.style.left = (e.clientX + 220) + 'px';
      preview.style.top = e.clientY + 'px';
    });
  });
})();
</script>
</Base>
