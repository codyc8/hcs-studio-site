<script is:inline>
// Hero rotating word
(function(){
  const words = ["is.","feels.","earns.","performs.","sells."];
  const rot = document.getElementById('rot');
  if (!rot) return;
  let i = 0;
  let live = rot.querySelector('span.in');
  function next(){
    i = (i + 1) % words.length;
    const incoming = document.createElement('span');
    incoming.textContent = words[i];
    rot.appendChild(incoming);
    requestAnimationFrame(()=>{
      requestAnimationFrame(()=>{
        incoming.classList.add('in');
        if (live) {
          live.classList.remove('in');
          live.classList.add('out');
          const dead = live;
          setTimeout(()=> dead.remove(), 700);
        }
        live = incoming;
      });
    });
  }
  setInterval(next, 2400);
})();

// Process scroll-driven animation
(function(){
  const stage = document.getElementById('processStage');
  const steps = document.querySelectorAll('.stage-step');
  const items = document.querySelectorAll('.process-step');
  const bar = document.getElementById('stageBar');
  if (!stage) return;
  const section = document.getElementById('process');

  function update(){
    const rect = section.getBoundingClientRect();
    const winH = window.innerHeight;
    const total = rect.height - winH;
    const scrolled = Math.min(Math.max(-rect.top, 0), total);
    const t = total > 0 ? scrolled / total : 0;
    const idx = Math.min(4, Math.floor(t * 5.0));
    const localT = (t * 5.0) - idx;
    steps.forEach((s, k) => s.classList.toggle('active', k === idx));
    items.forEach((s, k) => s.classList.toggle('dim', k !== idx));
    bar.style.width = (((idx + Math.min(1, localT)) / 5) * 100) + '%';
  }
  document.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
})();
</script>

